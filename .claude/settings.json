{
  "autoMemoryEnabled": true,
  "includeGitInstructions": true,
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "openrouter.ai",
        "api.tavily.com",
        "registry.npmjs.org",
        "pypi.org",
        "github.com",
        "api.github.com"
      ],
      "allowLocalBinding": true
    }
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_AUTOCOMPACT_PCT_OVERRIDE": "85"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Git branch: $(git branch --show-current 2>/dev/null || echo 'N/A') | Last commit: $(git log --oneline -1 2>/dev/null || echo 'N/A')\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[Post-Compact] Branch: $(git branch --show-current 2>/dev/null) | Modified: $(git diff --name-only 2>/dev/null | wc -l | tr -d ' ') files\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-dangerous-commands.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-files.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-lint.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-compact-save.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/desktop-notify.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && cd backend && python -m pytest 2>&1 | tail -5",
            "timeout": 120
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== Backend ===' && cd \"$CLAUDE_PROJECT_DIR\"/backend && python -m pytest 2>&1 | tail -5 && echo '=== Frontend ===' && cd \"$CLAUDE_PROJECT_DIR\"/frontend && npm run build 2>&1 | tail -3",
            "timeout": 180
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run lint*)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(npx next*)",
      "Bash(pytest*)",
      "Bash(python -m pytest*)",
      "Bash(alembic*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(npm install*)",
      "Bash(pip install*)"
    ],
    "deny": [
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(backend/.env)",
      "Read(backend/.env.*)"
    ]
  }
}
